# ── Secrets and environment ────────────────────────────────────────────────────
.env
.env.*          # .env.local, .env.production, etc. — but NOT .env.example
*.env           # any file whose name ends in .env
*.key           # private key files
*.pem           # certificate / private key files

# ── Runtime data (generated, never committed) ──────────────────────────────────
backend/data/
backend/logs/
**/.chroma/

# ── Python build artifacts ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
coverage.xml

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS metadata ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
