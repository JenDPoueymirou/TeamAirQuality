# ── LLM ───────────────────────────────────────────────────────
# Gemini 2.0 Flash — free at aistudio.google.com, no credit card needed
# 1,500 requests/day  |  15 requests/minute  |  1M token context
# Get your key: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Air Quality Data Sources ──────────────────────────────────
# AirNow — free, register at docs.airnowapi.org/account/request
AIRNOW_API_KEY=your_airnow_key_here
# PurpleAir — free, register at develop.purpleair.com
PURPLEAIR_API_KEY=your_purpleair_key_here

# ── Data Paths ────────────────────────────────────────────────
CSV_PATH=data/merged_final.csv
CHROMA_DIR=data/.chroma

# ── Model Settings ────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004
TOP_K=8
LLM_MAX_TOKENS=512

# ── Streamlit frontend ────────────────────────────────────────
# Set this when running app.py so the UI knows where the API lives
API_URL=https://your-service.onrender.com
